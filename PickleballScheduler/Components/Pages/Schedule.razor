@page "/event/{EventId:int}/schedule"
@inject EventService EventService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Schedule</PageTitle>

@if (evt == null)
{
    <p>Loading...</p>
}
else
{
    <div class="schedule-header">
        <h1 class="mb-1">@evt.Name</h1>
        <p class="text-muted mb-2">@evt.Date.ToString("MMMM d, yyyy") &middot; @evt.EventPlayers.Count players &middot; @courtNames.Count courts</p>
        <div class="no-print">
            <a href="/event/@evt.Id/setup" class="btn btn-outline-secondary btn-sm me-2">Edit Setup</a>
            <button class="btn btn-outline-primary btn-sm" @onclick="Print">Print Schedule</button>
        </div>
    </div>

    @if (evt.Rounds.Count == 0)
    {
        <div class="alert alert-info">No schedule generated yet. <a href="/event/@evt.Id/setup">Go to setup</a> to generate one.</div>
    }
    else
    {
        <table class="table table-bordered schedule-table mt-3">
            <thead>
                <tr>
                    <th class="round-col">Round</th>
                    @foreach (var courtName in courtNames)
                    {
                        <th class="text-center">@courtName</th>
                    }
                    <th class="text-center bye-col">Bye</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var round in evt.Rounds.OrderBy(r => r.RoundNumber))
                {
                    <tr>
                        <td class="fw-bold text-center align-middle">@round.RoundNumber</td>
                        @for (int c = 0; c < courtNames.Count; c++)
                        {
                            var courtNum = c + 1;
                            var match = round.Matches.FirstOrDefault(m => m.CourtNumber == courtNum);
                            <td class="text-center align-middle">
                                @if (match != null)
                                {
                                    <span>@match.Team1Player1.Name &amp; @match.Team1Player2.Name</span>
                                    <br />
                                    <small class="text-muted">vs</small>
                                    <br />
                                    <span>@match.Team2Player1.Name &amp; @match.Team2Player2.Name</span>
                                }
                            </td>
                        }
                        <td class="text-center align-middle text-muted fst-italic">
                            @if (round.Byes.Any())
                            {
                                @string.Join(", ", round.Byes.Select(b => b.Player.Name))
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public int EventId { get; set; }

    private Event? evt;
    private List<string> courtNames = new();

    protected override async Task OnInitializedAsync()
    {
        evt = await EventService.GetByIdAsync(EventId);
        if (evt != null)
        {
            courtNames = evt.GetCourtNamesList();
        }
    }

    private async Task Print()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}
