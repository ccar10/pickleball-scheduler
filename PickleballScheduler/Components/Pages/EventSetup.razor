@page "/event/new"
@page "/event/{EventId:int}/setup"
@inject EventService EventService
@inject PlayerService PlayerService
@inject ScheduleGenerator ScheduleGenerator
@inject NavigationManager Nav
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Event Setup</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@(isNew ? "New Event" : "Edit Event")</h1>
    @if (isNew)
    {
        <button class="btn btn-outline-danger btn-sm" @onclick="ResetForm">Reset</button>
    }
</div>

<div class="row">
    <div class="col-md-6">
        <div class="mb-3">
            <label class="form-label">Event Name</label>
            <input type="text" class="form-control" @bind="eventName" @bind:after="SaveToLocalStorage" />
        </div>
        <div class="mb-3">
            <label class="form-label">Date</label>
            <input type="date" class="form-control" @bind="eventDate" @bind:after="SaveToLocalStorage" />
        </div>

        <div class="mb-3">
            <label class="form-label">Courts</label>
            <div class="list-group mb-2">
                @for (int i = 0; i < courtNames.Count; i++)
                {
                    var index = i;
                    <div class="list-group-item d-flex align-items-center gap-2 py-1">
                        <input type="text" class="form-control form-control-sm" value="@courtNames[index]"
                               @onchange="e => UpdateCourtName(index, e)" />
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCourt(index)"
                                disabled="@(courtNames.Count <= 1)">X</button>
                    </div>
                }
            </div>
            <button class="btn btn-outline-secondary btn-sm" @onclick="AddCourt">+ Add Court</button>
            @{
                var playersNeeded = courtNames.Count * 4;
                var usableCourts = Math.Min(courtNames.Count, players.Count / 4);
            }
            @if (players.Count > 0 && usableCourts < courtNames.Count)
            {
                <div class="mt-1">
                    <small class="text-warning">Need @playersNeeded players for @courtNames.Count courts (@players.Count entered)</small>
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Number of Rounds</label>
            <input type="number" class="form-control" @bind="numberOfRounds" @bind:after="SaveToLocalStorage" min="1" />
            <small class="text-muted">Max before partner repeats: @(players.Count > 0 ? players.Count - 1 : 0)</small>
        </div>
    </div>

    <div class="col-md-6">
        <h5>Players <span class="text-muted fs-6">(@players.Count)</span></h5>

        <div class="list-group mb-3" style="max-height: 350px; overflow-y: auto;">
            @for (int i = 0; i < players.Count; i++)
            {
                var index = i;
                var p = players[index];
                <div class="list-group-item d-flex align-items-center gap-2">
                    <span class="text-muted" style="min-width: 24px;">@(index + 1).</span>
                    <input type="text" class="form-control form-control-sm" value="@p.Name"
                           @onchange="e => UpdateName(index, e)" placeholder="Name" />
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePlayer(index)">X</button>
                </div>
            }
        </div>

        <div class="input-group mb-3">
            <input type="text" class="form-control" placeholder="Add player name..." @bind="newPlayerName"
                   @onkeydown="HandleKeyDown" />
            <button class="btn btn-outline-secondary" @onclick="AddPlayer">Add</button>
        </div>

        @if (!string.IsNullOrEmpty(validationError))
        {
            <div class="alert alert-danger">@validationError</div>
        }

        <button class="btn btn-success w-100" @onclick="GenerateSchedule" disabled="@isGenerating">
            @(isGenerating ? "Generating..." : "Generate Schedule")
        </button>
    </div>
</div>

@code {
    [Parameter] public int? EventId { get; set; }

    private bool isNew => EventId == null;
    private string eventName = "Pickleball Session";
    private DateTime eventDate = DateTime.Today;
    private List<string> courtNames = new() { "Court 1", "Court 2" };
    private int numberOfRounds = 5;
    private List<PlayerEntry> players = new();
    private string newPlayerName = "";
    private string? validationError;
    private bool isGenerating;

    private const string StorageKey = "pb-event-setup";

    private class PlayerEntry
    {
        public string Name { get; set; } = "";
    }

    private class SavedState
    {
        public string EventName { get; set; } = "";
        public string EventDate { get; set; } = "";
        public List<string> CourtNames { get; set; } = new();
        public int NumberOfRounds { get; set; }
        public List<string> PlayerNames { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        if (EventId.HasValue)
        {
            var evt = await EventService.GetByIdAsync(EventId.Value);
            if (evt != null)
            {
                eventName = evt.Name;
                eventDate = evt.Date;
                courtNames = evt.GetCourtNamesList();
                players = evt.EventPlayers.Select(ep => new PlayerEntry
                {
                    Name = ep.Player.Name
                }).ToList();
                numberOfRounds = evt.Rounds.Count > 0 ? evt.Rounds.Count : Math.Max(1, players.Count - 1);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && isNew)
        {
            await LoadFromLocalStorage();
            StateHasChanged();
        }
    }

    private async Task LoadFromLocalStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
            if (string.IsNullOrEmpty(json)) return;

            var state = System.Text.Json.JsonSerializer.Deserialize<SavedState>(json);
            if (state == null) return;

            if (!string.IsNullOrEmpty(state.EventName)) eventName = state.EventName;
            if (DateTime.TryParse(state.EventDate, out var date)) eventDate = date;
            if (state.CourtNames.Count > 0) courtNames = state.CourtNames;
            if (state.NumberOfRounds > 0) numberOfRounds = state.NumberOfRounds;
            if (state.PlayerNames.Count > 0)
                players = state.PlayerNames.Select(n => new PlayerEntry { Name = n }).ToList();
        }
        catch { }
    }

    private async Task SaveToLocalStorage()
    {
        if (!isNew) return;
        try
        {
            var state = new SavedState
            {
                EventName = eventName,
                EventDate = eventDate.ToString("yyyy-MM-dd"),
                CourtNames = courtNames,
                NumberOfRounds = numberOfRounds,
                PlayerNames = players.Select(p => p.Name).ToList()
            };
            var json = System.Text.Json.JsonSerializer.Serialize(state);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch { }
    }

    private async Task ResetForm()
    {
        eventName = "Pickleball Session";
        eventDate = DateTime.Today;
        courtNames = new() { "Court 1", "Court 2" };
        numberOfRounds = 5;
        players = new();
        newPlayerName = "";
        validationError = null;
        try { await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey); } catch { }
    }

    private async Task AddCourt()
    {
        courtNames.Add($"Court {courtNames.Count + 1}");
        await SaveToLocalStorage();
    }

    private async Task RemoveCourt(int index)
    {
        if (courtNames.Count > 1)
        {
            courtNames.RemoveAt(index);
            await SaveToLocalStorage();
        }
    }

    private async Task UpdateCourtName(int index, ChangeEventArgs e)
    {
        courtNames[index] = e.Value?.ToString() ?? $"Court {index + 1}";
        await SaveToLocalStorage();
    }

    private async Task AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(newPlayerName)) return;
        players.Add(new PlayerEntry { Name = newPlayerName.Trim() });
        newPlayerName = "";
        await SaveToLocalStorage();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = AddPlayer();
        }
    }

    private async Task RemovePlayer(int index)
    {
        players.RemoveAt(index);
        await SaveToLocalStorage();
    }

    private async Task UpdateName(int index, ChangeEventArgs e)
    {
        players[index].Name = e.Value?.ToString() ?? "";
        await SaveToLocalStorage();
    }

    private async Task GenerateSchedule()
    {
        validationError = null;

        // Remove any blank names
        players.RemoveAll(p => string.IsNullOrWhiteSpace(p.Name));

        if (players.Count < 4)
        {
            validationError = "Please enter at least 4 players.";
            return;
        }
        if (courtNames.Count < 1)
        {
            validationError = "Need at least 1 court.";
            return;
        }

        isGenerating = true;

        var numberOfCourts = courtNames.Count;
        var courtNamesStr = string.Join(";", courtNames);

        // Create event
        Event evt;
        if (isNew)
        {
            evt = await EventService.CreateAsync(eventName, eventDate, numberOfCourts, courtNamesStr);
        }
        else
        {
            evt = (await EventService.GetByIdAsync(EventId!.Value))!;
            evt.Name = eventName;
            evt.Date = eventDate;
            evt.NumberOfCourts = numberOfCourts;
            evt.CourtNames = courtNamesStr;
        }

        // Create fresh player records for this event
        var dbPlayers = new List<Player>();
        foreach (var p in players)
        {
            var player = await PlayerService.CreateAsync(p.Name);
            dbPlayers.Add(player);
        }

        await EventService.SetPlayersAsync(evt.Id, dbPlayers.Select(p => p.Id).ToList());

        var rounds = ScheduleGenerator.Generate(dbPlayers, numberOfCourts, numberOfRounds);
        await EventService.SaveScheduleAsync(evt.Id, rounds);

        isGenerating = false;
        Nav.NavigateTo($"/event/{evt.Id}/schedule");
    }
}
