@page "/event/new"
@page "/event/{EventId:int}/setup"
@inject EventService EventService
@inject PlayerService PlayerService
@inject ScheduleGenerator ScheduleGenerator
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Event Setup</PageTitle>

<h1>@(isNew ? "New Event" : "Edit Event")</h1>

<div class="row">
    <div class="col-md-6">
        <div class="mb-3">
            <label class="form-label">Event Name</label>
            <input type="text" class="form-control" @bind="eventName" />
        </div>
        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Date</label>
                <input type="date" class="form-control" @bind="eventDate" />
            </div>
            <div class="col">
                <label class="form-label">Courts</label>
                <input type="number" class="form-control" @bind="numberOfCourts" min="1" />
                @{
                    var playersNeeded = numberOfCourts * 4;
                    var usableCourts = Math.Min(numberOfCourts, players.Count / 4);
                }
                @if (players.Count > 0 && usableCourts < numberOfCourts)
                {
                    <small class="text-warning">Need @playersNeeded players for @numberOfCourts courts (@players.Count entered)</small>
                }
            </div>
        </div>
        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="skillBalance" @bind="useSkillBalancing" />
            <label class="form-check-label" for="skillBalance">Use Skill Balancing (DUPR)</label>
        </div>

        <div class="mb-3">
            <label class="form-label">Number of Rounds</label>
            <input type="number" class="form-control" @bind="numberOfRounds" min="1" />
            <small class="text-muted">Max before partner repeats: @(players.Count > 0 ? players.Count - 1 : 0)</small>
        </div>
    </div>

    <div class="col-md-6">
        <h5>Players <span class="text-muted fs-6">(@players.Count)</span></h5>

        <div class="list-group mb-3" style="max-height: 350px; overflow-y: auto;">
            @for (int i = 0; i < players.Count; i++)
            {
                var index = i;
                var p = players[index];
                <div class="list-group-item d-flex align-items-center gap-2">
                    <span class="text-muted" style="min-width: 24px;">@(index + 1).</span>
                    <input type="text" class="form-control form-control-sm" value="@p.Name"
                           @onchange="e => UpdateName(index, e)" placeholder="Name" />
                    <input type="number" class="form-control form-control-sm text-center" style="max-width: 80px;"
                           value="@p.DuprRating" step="0.1" placeholder="DUPR"
                           @onchange="e => UpdateRating(index, e)" />
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePlayer(index)">X</button>
                </div>
            }
        </div>

        <div class="input-group mb-3">
            <input type="text" class="form-control" placeholder="Add player name..." @bind="newPlayerName"
                   @onkeydown="HandleKeyDown" />
            <input type="number" class="form-control" placeholder="DUPR" @bind="newPlayerRating"
                   step="0.1" style="max-width: 100px;" />
            <button class="btn btn-outline-secondary" @onclick="AddPlayer">Add</button>
        </div>

        @if (!string.IsNullOrEmpty(validationError))
        {
            <div class="alert alert-danger">@validationError</div>
        }

        <button class="btn btn-success w-100" @onclick="GenerateSchedule" disabled="@isGenerating">
            @(isGenerating ? "Generating..." : "Generate Schedule")
        </button>
    </div>
</div>

@code {
    [Parameter] public int? EventId { get; set; }

    private bool isNew => EventId == null;
    private string eventName = "Pickleball Session";
    private DateTime eventDate = DateTime.Today;
    private int numberOfCourts = 2;
    private int numberOfRounds = 5;
    private bool useSkillBalancing;
    private List<PlayerEntry> players = new();
    private string newPlayerName = "";
    private decimal? newPlayerRating;
    private string? validationError;
    private bool isGenerating;

    private class PlayerEntry
    {
        public string Name { get; set; } = "";
        public decimal? DuprRating { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (EventId.HasValue)
        {
            var evt = await EventService.GetByIdAsync(EventId.Value);
            if (evt != null)
            {
                eventName = evt.Name;
                eventDate = evt.Date;
                numberOfCourts = evt.NumberOfCourts;
                useSkillBalancing = evt.UseSkillBalancing;
                players = evt.EventPlayers.Select(ep => new PlayerEntry
                {
                    Name = ep.Player.Name,
                    DuprRating = ep.Player.DuprRating
                }).ToList();
                numberOfRounds = evt.Rounds.Count > 0 ? evt.Rounds.Count : Math.Max(1, players.Count - 1);
            }
        }
    }

    private void AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(newPlayerName)) return;
        players.Add(new PlayerEntry { Name = newPlayerName.Trim(), DuprRating = newPlayerRating });
        newPlayerName = "";
        newPlayerRating = null;
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddPlayer();
        }
    }

    private void RemovePlayer(int index)
    {
        players.RemoveAt(index);
    }

    private void UpdateName(int index, ChangeEventArgs e)
    {
        players[index].Name = e.Value?.ToString() ?? "";
    }

    private void UpdateRating(int index, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var rating))
            players[index].DuprRating = rating;
        else
            players[index].DuprRating = null;
    }

    private async Task GenerateSchedule()
    {
        validationError = null;

        // Remove any blank names
        players.RemoveAll(p => string.IsNullOrWhiteSpace(p.Name));

        if (players.Count < 4)
        {
            validationError = "Please enter at least 4 players.";
            return;
        }
        if (numberOfCourts < 1)
        {
            validationError = "Need at least 1 court.";
            return;
        }

        isGenerating = true;

        // Create event
        Event evt;
        if (isNew)
        {
            evt = await EventService.CreateAsync(eventName, eventDate, numberOfCourts, useSkillBalancing);
        }
        else
        {
            evt = (await EventService.GetByIdAsync(EventId!.Value))!;
            evt.Name = eventName;
            evt.Date = eventDate;
            evt.NumberOfCourts = numberOfCourts;
            evt.UseSkillBalancing = useSkillBalancing;
        }

        // Create fresh player records for this event
        var dbPlayers = new List<Player>();
        foreach (var p in players)
        {
            var player = await PlayerService.CreateAsync(p.Name, p.DuprRating);
            dbPlayers.Add(player);
        }

        await EventService.SetPlayersAsync(evt.Id, dbPlayers.Select(p => p.Id).ToList());

        var rounds = ScheduleGenerator.Generate(dbPlayers, numberOfCourts, numberOfRounds, useSkillBalancing);
        await EventService.SaveScheduleAsync(evt.Id, rounds);

        isGenerating = false;
        Nav.NavigateTo($"/event/{evt.Id}/schedule");
    }
}
