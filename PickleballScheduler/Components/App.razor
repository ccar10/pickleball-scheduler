<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" type="image/png" href="/images/NEPC-Favicon.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="app.css?v=@CacheBuster" />
    <link rel="stylesheet" href="PickleballScheduler.styles.css?v=@CacheBuster" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.pbHelpers = {
            scrollToBottom: function (el) { if (el) el.scrollTop = el.scrollHeight; },
            confirm: function (msg) { return window.confirm(msg); }
        };
    </script>
</body>

</html>

@code {
    private static readonly string CacheBuster =
        File.GetLastWriteTimeUtc(System.Reflection.Assembly.GetEntryAssembly()!.Location).Ticks.ToString();
}
